{
  "name": "@orbital/web",
  "version": "2.0.0",
  "description": "Orbital Traffic web client — React + Three.js (r3f) PWA, wrappable as a native app via Capacitor.",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview --port 4173",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "test:e2e": "playwright test",
    "cap:sync": "cap sync"
  },
  "dependencies": {
    "@orbital/core": "workspace:*",
    "@orbital/data": "workspace:*",
    "@orbital/ui-tokens": "workspace:*",
    "@react-three/fiber": "^9.0.4",
    "@tanstack/react-query": "^5.64.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "satellite.js": "^5.0.0",
    "three": "^0.171.0",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@capacitor/cli": "^6.2.0",
    "@capacitor/core": "^6.2.0",
    "@playwright/test": "^1.49.1",
    "@types/react": "^19.0.7",
    "@types/react-dom": "^19.0.3",
    "@types/three": "^0.171.0",
    "@vitejs/plugin-react": "^4.3.4",
    "typescript": "^5.7.3",
    "vite": "^6.0.7",
    "vite-plugin-pwa": "^0.21.1",
    "workbox-window": "^7.3.0"
  }
}
