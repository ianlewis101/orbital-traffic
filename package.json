{
  "name": "orbital-traffic",
  "version": "2.0.0",
  "private": true,
  "description": "Real-time 3D space-situational-awareness display. Monorepo: framework-agnostic orbital-mechanics core + React/Three.js PWA + Cloudflare edge.",
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "web": "pnpm --filter @orbital/web",
    "data:refresh": "tsx tooling/refresh-catalog.ts"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@orbital/core": "workspace:*",
    "@types/node": "^22.10.5",
    "eslint": "^9.18.0",
    "globals": "^15.14.0",
    "prettier": "^3.4.2",
    "tsx": "^4.19.2",
    "turbo": "^2.3.3",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  }
}
